# ── LLM Provider ──────────────────────────────────────────────
# Supported: ollama_cloud | groq | openrouter | cerebras | ollama | anthropic | google_genai
LLM_PROVIDER=ollama_cloud
LLM_MODEL=qwen2.5-coder:7b

# ── API Keys (set only what you need) ────────────────────────
GROQ_API_KEY=your-groq-api-key
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── OpenRouter ───────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key

# ── Ollama Cloud ─────────────────────────────────────────────
OLLAMA_CLOUD_BASE_URL=https://api.ollama.com
OLLAMA_CLOUD_API_KEY=your-ollama-cloud-api-key

# ── Ollama Local (no API key needed) ─────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# ── Web Search (optional) ────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key

# ── LangSmith Tracing (optional) ─────────────────────────────
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=coding-agentoptional) ─────────────────────────────
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=coding-agent